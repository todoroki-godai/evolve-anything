#!/usr/bin/env python3
"""bin/rl-evolve — rl-anything 3ステージ自律進化パイプライン CLI。

Usage:
    rl-evolve [options]

See `rl-evolve --help` for full options.
"""
import sys
from pathlib import Path

# bin/ → plugin_root/scripts/lib/
_lib = Path(__file__).resolve().parent.parent / "scripts" / "lib"
_evolve_scripts = Path(__file__).resolve().parent.parent / "skills" / "evolve" / "scripts"
sys.path.insert(0, str(_lib))
sys.path.insert(0, str(_evolve_scripts))

from evolve import main

if __name__ == "__main__":
    main()
